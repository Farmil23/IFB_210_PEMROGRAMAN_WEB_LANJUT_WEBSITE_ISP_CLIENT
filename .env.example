# Salin file ini menjadi .env dan isi nilainya.

DATABASE_URI=mysql+pymysql://user:pass@host:port/dbname
SECRET_KEY=ganti-dengan-secret-aman

# Produksi: router wajib ada di database untuk checkout voucher.
# Presentasi / demo: set false agar bisa jual voucher tanpa router (lokasi demo otomatis).
PRODUCTION=false


DEMO_RESET_ON_START=true

# --- Pembayaran Stripe + n8n ---
# URL publik aplikasi (tanpa slash di akhir).
# Lokal: http://127.0.0.1:5000
# Hugging Face Space: https://USERNAME-NAMASPACE.hf.space
APP_BASE_URL=http://127.0.0.1:5000 

# Zona waktu aplikasi: WIB (Asia/Jakarta) — diatur di app/timezone_util.py

# Di workflow n8n (create_checkout), wajib set Stripe:
#   success_url = {{ $json.success_url }}   (dari payload Flask)
#   cancel_url  = {{ $json.cancel_url }}
# Setelah pembayaran sukses, n8n bisa POST ke:
#   {{ APP_BASE_URL }}/api/payment-success
#   body: { "transaction_id": <id> }
# ATAU cukup andalkan redirect user ke:
#   {{ APP_BASE_URL }}/payment/complete/<transaction_id>
